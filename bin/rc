#!/usr/bin/env bash
# rc — manage Claude Code remote-control sessions (tmux + supervisor loop + native RC).
#
# Desired state:  ~/.config/claude-rc/desired   ("name|dir|uuid" per line)
# Kept alive by:  each session's claude-rc-loop + claude-rc-reconcile.timer.
#
#   rc up [name]      register cwd + start in RC. If the name is new and the folder
#                     has past conversations, interactively pick one (or start fresh).
#   rc up --new [name]  always start a fresh conversation (no picker)
#   rc pick [name]    re-point a session to another past conversation
#                     (no name: pick the session from a list first, then the chat)
#   rc down [name]    stop the tmux session and unregister (default: cwd folder name)
#   rc ls             list desired sessions: live state + UUID + dir
#   rc attach [name]  attach to a live session locally; no name = pick from a list (Ctrl-b d detaches)
#   rc sync           capture each live session's CURRENT conversation into desired
#   rc reconcile      run the reconciler once (normally automatic)
set -euo pipefail

DESIRED="${CLAUDE_RC_DESIRED:-$HOME/.config/claude-rc/desired}"
RECONCILE="$HOME/.local/bin/claude-rc-reconcile"
mkdir -p "$(dirname "$DESIRED")"
touch "$DESIRED"

die() { echo "rc: $*" >&2; exit 1; }

# ---- desired-state helpers --------------------------------------------------
get_uuid() {  # name -> existing uuid (or empty)
  awk -F'|' -v n="$1" '$1==n{print $3; exit}' "$DESIRED"
}
register() {  # name dir uuid — upsert keyed by EXACT name
  local name="$1" dir="$2" uuid="$3" tmp
  tmp="$(mktemp)"
  awk -F'|' -v n="$name" -v d="$dir" -v u="$uuid" '$1==n{next}{print}END{print n"|"d"|"u}' "$DESIRED" > "$tmp"
  mv "$tmp" "$DESIRED"
}
unregister() {  # name
  local name="$1" tmp
  tmp="$(mktemp)"
  awk -F'|' -v n="$name" '$1!=n' "$DESIRED" > "$tmp"
  mv "$tmp" "$DESIRED"
}

# ---- conversation discovery / interactive picker ----------------------------
slug_of() { printf '%s' "$1" | sed 's/[^a-zA-Z0-9]/-/g'; }

_convo_preview() {  # jsonl-file -> short one-line preview (best effort)
  command -v python3 >/dev/null 2>&1 || return 0
  python3 - "$1" <<'PY' 2>/dev/null || true
import json, sys
txt = ""
try:
    with open(sys.argv[1]) as fh:
        for line in fh:
            try: d = json.loads(line)
            except Exception: continue
            if d.get("type") == "summary" and d.get("summary"):
                txt = d["summary"]; break
            m = d.get("message")
            if isinstance(m, dict) and m.get("role") == "user":
                c = m.get("content")
                if isinstance(c, str): txt = c
                elif isinstance(c, list):
                    for it in c:
                        if isinstance(it, dict) and it.get("type") == "text":
                            txt = it.get("text", ""); break
                t = txt.strip()
                if t and not t.startswith("<"):  # skip /command + caveat wrappers
                    txt = t; break
                txt = ""
except Exception:
    pass
print(" ".join(txt.split())[:70])
PY
}

# Emit "uuid<TAB>display" for past conversations in DIR, newest first (max 50).
_convo_rows() {
  local dir="$1" proj f uuid when prev
  proj="$HOME/.claude/projects/$(slug_of "$dir")"
  [[ -d "$proj" ]] || return 0
  for f in $(ls -1t "$proj"/*.jsonl 2>/dev/null | head -50); do
    uuid="$(basename "$f" .jsonl)"
    when="$(date -r "$f" '+%Y-%m-%d %H:%M' 2>/dev/null || echo '?')"
    prev="$(_convo_preview "$f")"
    printf '%s\t%s  %s  %s\n' "$uuid" "${uuid:0:8}" "$when" "${prev:-(no preview)}"
  done
}

# Interactively pick a conversation in DIR. Echoes the chosen UUID, empty for
# "new conversation", and returns 1 if the user cancelled.
pick_convo() {
  local dir="$1" rows
  rows="$(_convo_rows "$dir")"
  [[ -z "$rows" ]] && return 0   # nothing to pick -> caller makes a fresh one
  if command -v fzf >/dev/null 2>&1; then
    local sel id
    sel="$( { printf '__new__\t✨ start a NEW conversation\n'; printf '%s\n' "$rows"; } \
            | fzf --with-nth=2.. --delimiter='\t' --height=45% --reverse --no-sort \
                  --prompt="pick conversation in $(basename "$dir") > " )" || return 1
    id="${sel%%$'\t'*}"
    [[ "$id" == "__new__" || -z "$id" ]] && return 0
    printf '%s\n' "$id"
  else
    local -a ids=("__new__") disp=("✨ start a NEW conversation") id d i choice
    while IFS=$'\t' read -r id d; do ids+=("$id"); disp+=("$d"); done <<< "$rows"
    echo "Conversations in $dir:" >&2
    for i in "${!disp[@]}"; do printf '  %2d) %s\n' "$i" "${disp[$i]}" >&2; done
    read -rp "Choose [0-$((${#ids[@]}-1))], or blank to cancel: " choice </dev/tty || return 1
    [[ -z "$choice" ]] && return 1
    [[ "$choice" =~ ^[0-9]+$ ]] || die "invalid choice"
    id="${ids[$choice]:-}"
    [[ "$id" == "__new__" || -z "$id" ]] && return 0
    printf '%s\n' "$id"
  fi
}

# ---- start / commands -------------------------------------------------------
_start_now() {  # name — start it via reconcile if not already live
  local name="$1"
  if tmux has-session -t "=$name" 2>/dev/null; then
    echo "rc: '$name' already live (remote-control)"
    return 0
  fi
  "$RECONCILE" >/dev/null 2>&1 || true
  sleep 1
  if tmux has-session -t "=$name" 2>/dev/null; then
    echo "rc: '$name' is live in remote-control"
  else
    echo "rc: '$name' registered but tmux did not start — check: rc reconcile"
  fi
}

cmd_up() {
  local force_new=0
  [[ "${1:-}" == "--new" || "${1:-}" == "-n" ]] && { force_new=1; shift; }
  local dir name uuid
  dir="$(pwd -P)"
  name="${1:-$(basename "$dir")}"
  case "$name" in *'|'*) die "name cannot contain '|'";; esac
  uuid="$(get_uuid "$name")"
  if [[ -z "$uuid" ]]; then
    if [[ $force_new -eq 0 && -t 0 && -t 1 ]]; then
      uuid="$(pick_convo "$dir")" || { echo "rc up: cancelled"; return 1; }
    fi
    [[ -z "$uuid" ]] && uuid="$(uuidgen)"
  fi
  register "$name" "$dir" "$uuid"
  echo "rc up: '$name'  ->  $dir   (uuid=${uuid:0:8})"
  _start_now "$name"
}

# Interactively choose a registered session. Echoes "name|dir", returns 1 on
# cancel / none. Auto-selects when there is only one.
pick_session_from_desired() {
  local -a keys=() disp=()
  local name dir uuid i
  while IFS='|' read -r name dir uuid; do
    [[ -z "$name" || "$name" == \#* ]] && continue
    keys+=("$name|$dir")
    disp+=("$(printf '%-22s %-10s %s' "$name" "${uuid:0:8}" "$dir")")
  done < "$DESIRED"
  [[ ${#keys[@]} -eq 0 ]] && { echo "rc: no registered sessions (rc up first)" >&2; return 1; }
  [[ ${#keys[@]} -eq 1 ]] && { printf '%s\n' "${keys[0]}"; return 0; }
  if command -v fzf >/dev/null 2>&1; then
    local tsv="" sel
    for i in "${!keys[@]}"; do tsv+="${disp[$i]}"$'\t'"${keys[$i]}"$'\n'; done
    sel="$(printf '%s' "$tsv" | fzf --with-nth=1 --delimiter='\t' --height=45% --reverse --prompt='pick session > ')" || return 1
    [[ -z "$sel" ]] && return 1
    printf '%s\n' "${sel#*$'\t'}"
  else
    local choice
    for i in "${!disp[@]}"; do printf '  %2d) %s\n' "$i" "${disp[$i]}" >&2; done
    read -rp "Session [0-$((${#keys[@]}-1))]: " choice </dev/tty || return 1
    [[ "$choice" =~ ^[0-9]+$ ]] || return 1
    printf '%s\n' "${keys[$choice]:-}"
  fi
}

cmd_pick() {
  local name dir uuid sel
  if [[ -n "${1:-}" ]]; then
    name="$1"
    case "$name" in *'|'*) die "name cannot contain '|'";; esac
    dir="$(awk -F'|' -v n="$name" '$1==n{print $2; exit}' "$DESIRED")"
    [[ -z "$dir" ]] && dir="$(pwd -P)"
  else
    sel="$(pick_session_from_desired)" || { echo "rc pick: cancelled"; return 1; }
    [[ -z "$sel" ]] && return 1
    name="${sel%%|*}"; dir="${sel#*|}"
  fi
  [[ -n "$(_convo_rows "$dir")" ]] || die "no past conversations in $dir (use: rc up --new \"$name\")"
  uuid="$(pick_convo "$dir")" || { echo "rc pick: cancelled"; return 1; }
  [[ -z "$uuid" ]] && uuid="$(uuidgen)"
  register "$name" "$dir" "$uuid"
  echo "rc pick: '$name'  ->  uuid=${uuid:0:8}"
  _start_now "$name"
}

cmd_down() {
  local name="${1:-$(basename "$(pwd -P)")}"
  unregister "$name"
  if tmux has-session -t "=$name" 2>/dev/null; then
    tmux kill-session -t "=$name"
    echo "rc down: '$name' stopped & unregistered"
  else
    echo "rc down: '$name' unregistered (was not live)"
  fi
}

cmd_ls() {
  printf '%-26s %-5s %-10s %s\n' NAME LIVE UUID DIR
  while IFS='|' read -r name dir uuid; do
    [[ -z "$name" || "$name" == \#* ]] && continue
    local live
    if tmux has-session -t "=$name" 2>/dev/null; then live=yes; else live=no; fi
    printf '%-26s %-5s %-10s %s\n' "$name" "$live" "${uuid:0:8}" "$dir"
  done < "$DESIRED"
}

# Interactively choose a live tmux session. Echoes the chosen name, returns 1 on
# cancel / none.
pick_live_session() {
  local live
  live="$(tmux list-sessions -F '#S' 2>/dev/null | sort)"
  [[ -z "$live" ]] && { echo "rc: no live sessions" >&2; return 1; }
  if command -v fzf >/dev/null 2>&1; then
    printf '%s\n' "$live" | fzf --height=40% --reverse --prompt="attach to > " || return 1
  else
    local -a arr; mapfile -t arr <<< "$live"
    local i choice
    for i in "${!arr[@]}"; do printf '  %2d) %s\n' "$i" "${arr[$i]}" >&2; done
    read -rp "Attach to [0-$((${#arr[@]}-1))]: " choice </dev/tty || return 1
    [[ "$choice" =~ ^[0-9]+$ ]] || return 1
    printf '%s\n' "${arr[$choice]:-}"
  fi
}

cmd_attach() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    local live; live="$(tmux list-sessions -F '#S' 2>/dev/null)"
    [[ -z "$live" ]] && die "no live sessions (rc up to start one)"
    if [[ "$(printf '%s\n' "$live" | grep -c .)" -eq 1 ]]; then
      name="$live"                       # only one live -> attach straight away
    else
      name="$(pick_live_session)" || { echo "rc attach: cancelled"; return 1; }
    fi
    [[ -z "$name" ]] && return 1
  fi
  tmux has-session -t "=$name" 2>/dev/null || die "no live session '$name' (rc ls to see them)"
  exec tmux attach -t "=$name"
}

usage() { sed -n '2,15p' "$0" | sed 's/^# \{0,1\}//'; }

case "${1:-}" in
  up)             shift; cmd_up "$@";;
  pick)           shift; cmd_pick "$@";;
  down)           shift; cmd_down "$@";;
  ls|list)        cmd_ls;;
  attach|a)       shift; cmd_attach "$@";;
  sync|reconcile) exec "$RECONCILE";;
  ""|-h|--help|help) usage;;
  *) die "unknown command '$1' (try: rc --help)";;
esac
